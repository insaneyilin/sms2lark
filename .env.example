# Webhook authentication token (shared with phone SMS forwarder app)
VCA_WEBHOOK_TOKEN=your-secret-token-here

# Registered phone numbers (JSON array). Only these phones can forward SMS.
VCA_REGISTERED_PHONES=["13800001111", "13900002222"]

# Lark CLI path
VCA_LARK_CLI_PATH=/opt/homebrew/bin/lark-cli

# Default subscribers (JSON array of open_id, always receive all codes)
VCA_DEFAULT_SUBSCRIBERS=["ou_xxxxxxxxxxxx"]

# Group chat IDs where bot listens for commands (JSON array)
VCA_GROUP_CHAT_IDS=[]

# Authorized users who can query/subscribe in group (JSON array, empty = allow all)
VCA_AUTHORIZED_USERS=[]

# Code expiry time in seconds (default 5 minutes)
VCA_CODE_TTL_SECONDS=300

# Server
VCA_HOST=0.0.0.0
VCA_PORT=8900
